generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "accounting"]
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  MAINTENANCE
  TENANT

  @@schema("public")
}

enum UnitType {
  RESIDENTIAL
  COMMERCIAL
  PARKING
  STORAGE

  @@schema("public")
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE

  @@schema("public")
}

enum PropertyStatus {
  ACTIVE
  INACTIVE

  @@schema("public")
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED

  @@schema("public")
}

enum ContractType {
  RESIDENTIAL_LEASE
  COMMERCIAL_LEASE
  PARKING
  STORAGE
  OTHER

  @@schema("public")
}

enum Currency {
  EUR
  USD
  GBP
  CHF

  @@schema("public")
}

enum AppLanguage {
  en
  de

  @@schema("public")
}

model SystemConfig {
  id              Int         @id @default(1)
  currency        Currency    @default(EUR)
  defaultLanguage AppLanguage @default(en)
  updatedAt       DateTime    @updatedAt

  @@schema("public")
  @@map("system_config")
}

model CompanyProfile {
  id         Int      @id @default(1)
  name       String   @default("")
  legalType  String   @default("")
  street     String   @default("")
  city       String   @default("")
  postalCode String   @default("")
  country    String   @default("")
  taxId      String   @default("")
  vatId      String   @default("")
  phone      String   @default("")
  email      String   @default("")
  logoPath   String?
  updatedAt  DateTime @updatedAt

  @@schema("public")
  @@map("company_profile")
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  passwordHash      String
  role              Role              @default(TENANT)
  firstName         String?
  lastName          String?
  username          String?           @unique
  phone             String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  refreshTokens     RefreshToken[]
  ownedAs           Owner?
  tenantProfile     Tenant?
  managedProperties PropertyManager[]

  @@schema("public")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenId   String    @unique
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@schema("public")
  @@map("refresh_tokens")
}

model Owner {
  id         String     @id @default(cuid())
  name       String
  email      String?
  phone      String?
  address    String?
  userId     String?    @unique
  user       User?      @relation(fields: [userId], references: [id])
  properties Property[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@schema("public")
  @@map("owners")
}

model Property {
  id             String            @id @default(cuid())
  name           String
  address        String
  city           String
  postalCode     String
  country        String            @default("DE")
  status         PropertyStatus    @default(ACTIVE)
  ownerId        String
  owner          Owner             @relation(fields: [ownerId], references: [id])
  units          Unit[]
  managers       PropertyManager[]
  yearBuilt      Int?
  numberOfFloors Int?
  description    String?
  notes          PropertyNote[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@schema("public")
  @@map("properties")
}

model PropertyNote {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  content     String
  createdById String
  createdAt   DateTime @default(now())

  @@schema("public")
  @@map("property_notes")
}

model PropertyManager {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([propertyId, userId])
  @@schema("public")
  @@map("property_managers")
}

model Unit {
  id         String     @id @default(cuid())
  name       String
  type       UnitType
  status     UnitStatus @default(VACANT)
  floor      Int?
  areaSqm    Decimal?   @db.Decimal(8, 2)
  rooms      Decimal?   @db.Decimal(4, 1)
  propertyId String
  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contracts  Contract[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@schema("public")
  @@map("units")
}

model Tenant {
  id                       String     @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  dateOfBirth              DateTime?
  address                  String?
  isCompany                Boolean    @default(false)
  companyName              String?
  legalForm                String?
  taxId                    String?
  commercialRegisterNumber String?
  userId                   String?    @unique
  user                     User?      @relation(fields: [userId], references: [id])
  contracts                Contract[]
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@schema("public")
  @@map("tenants")
}

model Contract {
  id            String         @id @default(cuid())
  unitId        String
  unit          Unit           @relation(fields: [unitId], references: [id])
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  startDate     DateTime
  endDate       DateTime?
  rentAmount    Decimal        @db.Decimal(10, 2)
  depositAmount Decimal?       @db.Decimal(10, 2)
  status        ContractStatus @default(ACTIVE)
  type          ContractType
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@schema("public")
  @@map("contracts")
}

// ─── Accounting Schema ─────────────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE

  @@schema("accounting")
}

model Account {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  nameDe       String
  type         AccountType
  parentId     String?
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  isSystem     Boolean       @default(false)
  description  String?
  journalLines JournalLine[]
  expenses     Expense[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@schema("accounting")
  @@map("accounts")
}

model JournalEntry {
  id          String        @id @default(cuid())
  date        DateTime
  description String
  reference   String?
  propertyId  String?
  createdById String
  lines       JournalLine[]
  createdAt   DateTime      @default(now())

  @@schema("accounting")
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0) @db.Decimal(15, 2)
  credit         Decimal      @default(0) @db.Decimal(15, 2)
  description    String?

  @@schema("accounting")
  @@map("journal_lines")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED

  @@schema("accounting")
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  DIRECT_DEBIT
  OTHER

  @@schema("accounting")
}

model Invoice {
  id             String        @id @default(cuid())
  contractId     String
  periodMonth    Int
  periodYear     Int
  amountDue      Decimal       @db.Decimal(10, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(10, 2)
  dueDate        DateTime
  issuedAt       DateTime?
  status         InvoiceStatus @default(DRAFT)
  journalEntryId String?
  payments       Payment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([contractId, periodMonth, periodYear])
  @@schema("accounting")
  @@map("invoices")
}

model Payment {
  id             String        @id @default(cuid())
  invoiceId      String
  invoice        Invoice       @relation(fields: [invoiceId], references: [id])
  amount         Decimal       @db.Decimal(10, 2)
  paymentDate    DateTime
  method         PaymentMethod @default(BANK_TRANSFER)
  reference      String?
  journalEntryId String?
  createdAt      DateTime      @default(now())

  @@schema("accounting")
  @@map("payments")
}

enum PayableStatus {
  PENDING
  PAID

  @@schema("accounting")
}

model Expense {
  id                String    @id @default(cuid())
  propertyId        String
  unitId            String?
  accountId         String
  account           Account   @relation(fields: [accountId], references: [id])
  amount            Decimal   @db.Decimal(10, 2)
  date              DateTime
  vendor            String?
  description       String
  receiptPath       String?
  isPaid            Boolean   @default(true)
  maintenanceTaskId String?
  journalEntryId    String?
  payable           Payable?
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@schema("accounting")
  @@map("expenses")
}

model Payable {
  id             String        @id @default(cuid())
  expenseId      String        @unique
  expense        Expense       @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  dueDate        DateTime
  status         PayableStatus @default(PENDING)
  paidAt         DateTime?
  journalEntryId String?

  @@schema("accounting")
  @@map("payables")
}

enum DepositStatus {
  HELD
  PARTIALLY_RETURNED
  FULLY_RETURNED
  FORFEITED

  @@schema("accounting")
}

model SecurityDeposit {
  id             String             @id @default(cuid())
  contractId     String
  propertyId     String
  amount         Decimal            @db.Decimal(10, 2)
  receivedDate   DateTime
  status         DepositStatus      @default(HELD)
  journalEntryId String?
  deductions     DepositDeduction[]
  refunds        DepositRefund[]
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@schema("accounting")
  @@map("security_deposits")
}

model DepositDeduction {
  id             String          @id @default(cuid())
  depositId      String
  deposit        SecurityDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)
  amount         Decimal         @db.Decimal(10, 2)
  reason         String
  accountId      String
  expenseId      String?
  journalEntryId String?
  createdAt      DateTime        @default(now())

  @@schema("accounting")
  @@map("deposit_deductions")
}

model DepositRefund {
  id             String          @id @default(cuid())
  depositId      String
  deposit        SecurityDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)
  amount         Decimal         @db.Decimal(10, 2)
  refundDate     DateTime
  reference      String?
  journalEntryId String?
  createdAt      DateTime        @default(now())

  @@schema("accounting")
  @@map("deposit_refunds")
}
