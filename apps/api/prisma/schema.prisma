generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "accounting"]
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  MAINTENANCE
  TENANT

  @@schema("public")
}

enum UnitType {
  RESIDENTIAL
  COMMERCIAL
  PARKING
  STORAGE

  @@schema("public")
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE

  @@schema("public")
}

enum PropertyStatus {
  ACTIVE
  INACTIVE

  @@schema("public")
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED

  @@schema("public")
}

enum ContractType {
  RESIDENTIAL_LEASE
  COMMERCIAL_LEASE
  PARKING
  STORAGE
  OTHER

  @@schema("public")
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  passwordHash      String
  role              Role              @default(TENANT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  refreshTokens     RefreshToken[]
  ownedAs           Owner?
  tenantProfile     Tenant?
  managedProperties PropertyManager[]

  @@schema("public")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenId   String    @unique
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@schema("public")
  @@map("refresh_tokens")
}

model Owner {
  id         String     @id @default(cuid())
  name       String
  email      String?
  phone      String?
  address    String?
  userId     String?    @unique
  user       User?      @relation(fields: [userId], references: [id])
  properties Property[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@schema("public")
  @@map("owners")
}

model Property {
  id             String            @id @default(cuid())
  name           String
  address        String
  city           String
  postalCode     String
  country        String            @default("DE")
  status         PropertyStatus    @default(ACTIVE)
  ownerId        String
  owner          Owner             @relation(fields: [ownerId], references: [id])
  units          Unit[]
  managers       PropertyManager[]
  yearBuilt      Int?
  numberOfFloors Int?
  description    String?
  notes          PropertyNote[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@schema("public")
  @@map("properties")
}

model PropertyNote {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  content     String
  createdById String
  createdAt   DateTime @default(now())

  @@schema("public")
  @@map("property_notes")
}

model PropertyManager {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([propertyId, userId])
  @@schema("public")
  @@map("property_managers")
}

model Unit {
  id         String     @id @default(cuid())
  name       String
  type       UnitType
  status     UnitStatus @default(VACANT)
  floor      Int?
  areaSqm    Decimal?   @db.Decimal(8, 2)
  rooms      Decimal?   @db.Decimal(4, 1)
  propertyId String
  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contracts  Contract[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@schema("public")
  @@map("units")
}

model Tenant {
  id                       String     @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  dateOfBirth              DateTime?
  address                  String?
  isCompany                Boolean    @default(false)
  companyName              String?
  legalForm                String?
  taxId                    String?
  commercialRegisterNumber String?
  userId                   String?    @unique
  user                     User?      @relation(fields: [userId], references: [id])
  contracts                Contract[]
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@schema("public")
  @@map("tenants")
}

model Contract {
  id            String         @id @default(cuid())
  unitId        String
  unit          Unit           @relation(fields: [unitId], references: [id])
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  startDate     DateTime
  endDate       DateTime?
  rentAmount    Decimal        @db.Decimal(10, 2)
  depositAmount Decimal?       @db.Decimal(10, 2)
  status        ContractStatus @default(ACTIVE)
  type          ContractType
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@schema("public")
  @@map("contracts")
}

// ─── Accounting Schema ─────────────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE

  @@schema("accounting")
}

model Account {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  nameDe       String
  type         AccountType
  parentId     String?
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  isSystem     Boolean       @default(false)
  description  String?
  journalLines JournalLine[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@schema("accounting")
  @@map("accounts")
}

model JournalEntry {
  id          String        @id @default(cuid())
  date        DateTime
  description String
  reference   String?
  propertyId  String?
  createdById String
  lines       JournalLine[]
  createdAt   DateTime      @default(now())

  @@schema("accounting")
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0) @db.Decimal(15, 2)
  credit         Decimal      @default(0) @db.Decimal(15, 2)
  description    String?

  @@schema("accounting")
  @@map("journal_lines")
}
