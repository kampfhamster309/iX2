{
  "name": "ix2",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @ix2/api dev\" \"pnpm --filter @ix2/web dev\"",
    "build": "pnpm --filter './apps/*' --filter './packages/*' run build",
    "lint": "eslint .",
    "test": "pnpm --filter './apps/*' --filter './packages/*' run test",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "simple-git-hooks": "^2.11.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
